# ─────────────────────────────────────────────────────────────
# AWS — DynamoDB credentials
# Use a dedicated IAM user with ONLY DynamoDB access scoped to
# the fep-* tables. Never use root keys.
# ─────────────────────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=AKIA_XXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─────────────────────────────────────────────────────────────
# JWT — auth signing secret
# Generate with: openssl rand -base64 64
# Must be at least 32 bytes for HS256 to be safe.
# ─────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

# ─────────────────────────────────────────────────────────────
# Gradi AI — video analysis service
# Default endpoint works as-is, override only if pointed elsewhere.
# ─────────────────────────────────────────────────────────────
GRADI_API_URL=https://gradi.ai/api/analyze-video

# ─────────────────────────────────────────────────────────────
# Public (browser-readable) — branding
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=FEP
NEXT_PUBLIC_BRAND=Adda247
